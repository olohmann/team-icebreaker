{
  "name": "icebreaker",
  "version": "1.0.0",
  "description": "Team-meeting icebreaker tool: anonymous cards with a staged reveal.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/http/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/http/server.js",
    "dev": "tsx watch src/http/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "azurite": "node scripts/start-azurite.mjs"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.1",
    "@azure/identity": "^4.13.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "azurite": "^3.34.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
