# --- Local development (Azurite emulator, shared-key) ---
# The Tables SDK does not understand this shortcut by itself; the adapter
# expands it to the full Azurite connection string.
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# --- Azure (Microsoft Entra ID / managed identity) ---
# When set, the app authenticates with DefaultAzureCredential instead of a
# shared key. Takes precedence over AZURE_STORAGE_CONNECTION_STRING.
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.table.core.windows.net

# Port the HTTP server listens on (App Service injects its own PORT).
PORT=3000
